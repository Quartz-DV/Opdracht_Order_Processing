<Window x:Class="Wpf_Order_Processing.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_Order_Processing"
        mc:Ignorable="d"
        Title="InfoWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="5"  Orientation="Horizontal">
            <StackPanel Orientation="Horizontal" >
                <TextBlock Margin="0,0,3,0" >Naam:</TextBlock>
                <TextBlock x:Name="nameText">John Doe</TextBlock>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                <TextBlock Margin="0,0,3,0">STATUS:</TextBlock>
                <TextBlock x:Name="status">GOLD</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                <TextBlock Margin="0,0,3,0">Adres:</TextBlock>
                <TextBlock x:Name="adres">GOLD</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                <TextBlock Margin="0,0,3,0">Email:</TextBlock>
                <TextBlock x:Name="email">GOLD</TextBlock>
            </StackPanel>
            <StackPanel>
                <Button x:Name="btnPrint">PRINT</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
