<Window x:Class="Wpf_Order_Processing.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_Order_Processing"
        mc:Ignorable="d"
        Title="InfoWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Button x:Name="VerzendButton" Content="Verzenden" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20" Grid.Column="2" Grid.Row="1" MinWidth="100" MinHeight="30" FontSize="20" Click="VerzendButton_Click"/>
        <TextBlock x:Name="Titel" Text="Bestellingsoverzicht" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="20"/>
        <TextBox x:Name="NaamOverzicht" Grid.Row="0" Grid.Column="0" Margin="20,50" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300" />
        <TextBox x:Name="AdresOverzicht" Grid.Row="0" Grid.Column="0" Margin="20,70" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
        <TextBox x:Name="EmailOverzicht" Grid.Row="0" Grid.Column="0" Margin="20,90" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
        <TextBox x:Name="StatusOverzicht" Grid.Row="0" Grid.Column="0" Margin="20,110" VerticalAlignment="Top" HorizontalAlignment="Left" Width="300"/>
        <TextBlock x:Name="GeleverdOp" Grid.Row="0" Grid.Column="0" Margin="20,130" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="16"/>
        <TextBlock x:Name="LeveringsDatum" Grid.Row="0" Grid.Column="0" Margin="164,130" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="16"/>
        <ListBox x:Name="lstEvents" Grid.Row="0" Grid.Column="1" Margin="1,1" DisplayMemberPath="Naam"/> 

        <TextBlock x:Name="ItemsTitel" Text="Items die worden bezorgd:" Grid.Row="0" Grid.Column="0" Margin="1"/>

    </Grid>
</Window>
