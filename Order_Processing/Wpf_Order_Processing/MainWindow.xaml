<Window x:Class="Wpf_Order_Processing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wpf_Order_Processing"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0" >
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock>Member (email)</TextBlock>
                <TextBox Width="155" x:Name="txtBoxEmail"></TextBox>

                <CheckBox Margin="5,0,0,0">Admin</CheckBox>
            </StackPanel>
            
            <StackPanel>
                <Button x:Name="btnLogIn" Click="btnLogIn_Click">LOGIN</Button>
            </StackPanel>
        </StackPanel>


    </Grid>
</Window>
