<Window x:Class="Wpf_Order_Processing.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdminPanel" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <DataGrid x:Name="DataGridBestellingen" Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Margin="10" 
                  AutoGenerateColumns="True" IsReadOnly="True" />

        <DataGrid x:Name="DataGridExtra" Grid.Row="2" Grid.Column="1" Margin="10" />

        <DataGrid x:Name="DataGridDetails" Grid.Row="1" Grid.Column="1" Margin="10" />

    </Grid>
</Window>